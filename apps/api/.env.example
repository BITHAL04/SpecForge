# SpecForge API Environment Variables
DATABASE_URL=postgresql+asyncpg://specforge:specforge@localhost:5432/specforge
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
